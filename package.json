{
  "name": "travelaround",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.9",
    "expo-constants": "~56.0.17",
    "expo-file-system": "~56.0.7",
    "expo-image-picker": "~56.0.16",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-location": "~56.0.16",
    "expo-router": "~56.2.9",
    "expo-status-bar": "~56.0.4",
    "lucide-react-native": "^1.17.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.2",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.4",
    "prettier": "^3.8.3",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write \"app/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx}\" \"docs/**/*.md\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx}\" \"docs/**/*.md\" \"*.{js,json,md}\"",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "private": true
}
