{
  "expo": {
    "name": "TravelAround",
    "slug": "travelaround",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "travelaround",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "TravelAround 会在你主动打卡时读取当前位置，用于判断附近可点亮地点。",
        "NSPhotoLibraryUsageDescription": "TravelAround 会在你主动选择时访问相册，用于给本地打卡记录添加照片。"
      }
    },
    "android": {
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TravelAround 会在你主动打卡时读取当前位置，用于判断附近可点亮地点。"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TravelAround 会在你主动选择时访问相册，用于给本地打卡记录添加照片。",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ]
    ]
  }
}
